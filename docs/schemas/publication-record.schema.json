{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slr-platform.local/schemas/publication-record.schema.json",
  "title": "CanonicalPublication",
  "type": "object",
  "required": [
    "record_id",
    "schema_version",
    "title",
    "authors",
    "provenance"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "abstract": {
      "type": ["string", "null"]
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["display_name"],
        "properties": {
          "display_name": {"type": "string"},
          "orcid": {"type": ["string", "null"]},
          "affiliations": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "publication_year": {
      "type": ["integer", "null"],
      "minimum": 1500,
      "maximum": 2200
    },
    "publication_date": {
      "type": ["string", "null"],
      "format": "date"
    },
    "doi": {
      "type": ["string", "null"]
    },
    "issn": {
      "type": "array",
      "items": {"type": "string"}
    },
    "isbn": {
      "type": "array",
      "items": {"type": "string"}
    },
    "venue": {
      "type": ["string", "null"]
    },
    "publisher": {
      "type": ["string", "null"]
    },
    "document_type": {
      "type": ["string", "null"]
    },
    "language": {
      "type": ["string", "null"]
    },
    "keywords": {
      "type": "array",
      "items": {"type": "string"}
    },
    "urls": {
      "type": "array",
      "items": {"type": "string", "format": "uri"}
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source",
          "source_record_id",
          "retrieved_at"
        ],
        "properties": {
          "source": {"type": "string"},
          "source_record_id": {"type": "string"},
          "retrieved_at": {
            "type": "string",
            "format": "date-time"
          },
          "query_id": {
            "type": ["string", "null"]
          },
          "raw_file": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
